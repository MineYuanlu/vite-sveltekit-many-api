{
	"name": "@yuanlu_yl/vite-sveltekit-many-api",
	"version": "0.2.0",
	"description": "Vite plugin for SvelteKit to auto-generate many API routes from `-api.server.ts`",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup src/index.ts --format cjs,esm --dts --clean && rm -rf dist/templates && node scripts/copy-templates.cjs",
		"dev": "tsup src/index.ts --format cjs,esm --dts --watch",
		"test": "vitest",
		"test:run": "vitest run",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src test",
		"lint:fix": "eslint src test --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"vite",
		"plugin",
		"sveltekit",
		"api",
		"routes",
		"openapi",
		"mcp",
		"server"
	],
	"author": "yuanlu",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MineYuanlu/vite-sveltekit-many-api.git"
	},
	"bugs": {
		"url": "https://github.com/MineYuanlu/vite-sveltekit-many-api/issues"
	},
	"homepage": "https://github.com/MineYuanlu/vite-sveltekit-many-api#readme",
	"peerDependencies": {
		"@standard-schema/spec": "^1.1.0",
		"vite": "^5.0.0 || ^6.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@standard-schema/spec": "^1.1.0",
		"@types/node": "^22.0.0",
		"eslint": "^10.4.0",
		"prettier": "^3.8.3",
		"tsup": "^8.0.0",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.59.3",
		"vite": "^6.0.0",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"es-module-lexer": "^1.6.0"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
